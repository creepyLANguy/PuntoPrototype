{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/app",
        "destination": "/app/index.html"
      },
      {
        "source": "/app/**",
        "destination": "/app/index.html"
      },
      {
        "source": "/nfc",
        "destination": "/nfcWriter/index.html"
      },
      {
        "source": "/nfc/**",
        "destination": "/nfcWriter/index.html"
      },
      {
        "source": "/watch",
        "destination": "/app/index.html"
      },
      {
        "source": "/watch/**",
        "destination": "/app/index.html"
      },
      {
        "source": "/view",
        "destination": "/app/index.html"
      },
      {
        "source": "/view/**",
        "destination": "/app/index.html"
      },
      {
        "source": "/spectate",
        "destination": "/app/index.html"
      },
      {
        "source": "/spectate/**",
        "destination": "/app/index.html"
      },
      {
        "source": "/play",
        "destination": "/app/index.html"
      },
      {
        "source": "/play/**",
        "destination": "/app/index.html"
      },
      {
        "source": "/join",
        "destination": "/app/index.html"
      },
      {
        "source": "/join/**",
        "destination": "/app/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": []
    }
  ]
}
